# buddy-note 환경변수 템플릿.
#
# 사용법:
#   cp .envs/example.env .envs/local.env
#   ln -sf .envs/local.env .env.local     # Next.js 는 루트 .env.local 만 인식
#
# .envs/ 하위는 example.env 와 .gitignore 만 커밋, 나머지(local.env 등)는 제외.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxx
ANTHROPIC_API_KEY=xxxxx

# Shared bearer for pg_cron → /api/memory/process. Generate with:
#   openssl rand -hex 32
# Must be set on Vercel AND inlined into the cron.schedule() SQL you run in
# Supabase Studio (see supabase/migrations/20260420000003_memory_worker_cron.sql).
MEMORY_WORKER_SECRET=
# Optional: override the default batch size (5). Keep small enough that
# one invocation stays under maxDuration (60s on Vercel Pro).
# MEMORY_WORKER_BATCH_SIZE=5

# Vercel Cron / ops route shared bearer. Generate with:
#   openssl rand -hex 32
# Vercel Cron sends this as Authorization: Bearer $CRON_SECRET when configured.
CRON_SECRET=
# Optional: split secret for /api/cleanup/orphan-images. Missing → CRON_SECRET fallback.
DIARY_IMAGE_CLEANUP_SECRET=

# Upstash Redis — rate limiting (10/h per user for diary, 60/min for memory worker).
# Create at https://console.upstash.com/redis → Region: ap-northeast-1 (Tokyo, closest to Seoul).
# Optional in dev: missing env = no rate limit (stub mode).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Site URL — metadataBase, OG absolute URLs, sitemap baseUrl.
# dev: http://localhost:4000, prod: https://buddy-note.vercel.app 등 실제 도메인.
NEXT_PUBLIC_SITE_URL=http://localhost:4000

# Kakao OAuth:
# 클라이언트 ID / 시크릿은 Supabase Dashboard → Authentication → Providers → Kakao 에 설정.
# 앱 코드는 supabase.auth.signInWithOAuth({provider:'kakao'}) 로 호출하므로
# Next.js env 는 별도 필요 없음. Kakao 비즈앱 승인 후 대시보드에서 활성화.

# Sentry — optional. Missing → no-op (dev에서 비용 없음).
# SENTRY_DSN 은 서버/edge 런타임용, NEXT_PUBLIC_SENTRY_DSN 은 브라우저용.
# 같은 DSN 을 양쪽에 써도 무방 (Sentry 가 환경 태그로 구분).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Source map 업로드용. 세 개 모두 있을 때만 withSentryConfig 가 업로드 실행.
# 하나라도 없으면 빌드는 통과하되 source map 단계만 건너뜀.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Sampling (0.0 ~ 1.0). 프로덕션 시작은 0.1 권장.
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
